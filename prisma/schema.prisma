// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Authentication & Authorization ──────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         UserRole @default(viewer)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // ── Email & verification (F4, F5, F6) ──
  email                        String?  @unique @db.VarChar(320)
  emailVerified                Boolean  @default(false) @map("email_verified")
  passwordChangedAfterCreation Boolean  @default(false) @map("password_changed_after_creation")
  createdBy                    String?  @map("created_by")

  // ── Account permissions (F2, F3) ──
  accountPermissions Json? @map("account_permissions") // JSONB permission matrix
  navTabOrder        Json? @map("nav_tab_order")        // JSONB array of tab_ids (F1)

  // ── Suspension (F13) ──
  suspended              Boolean   @default(false)
  suspendedAt            DateTime? @map("suspended_at")
  suspendedReason        String?   @map("suspended_reason")
  suspendedManually      Boolean   @default(false) @map("suspended_manually")
  failedLoginAttempts    Int       @default(0) @map("failed_login_attempts")
  lastFailedLoginAt      DateTime? @map("last_failed_login_at")
  forceResetOnLogin      Boolean   @default(false) @map("force_reset_on_login")

  // ── 2FA scaffold (F15) ──
  totpSecret      String?  @map("totp_secret") @db.VarChar(256)
  totpEnabled     Boolean  @default(false) @map("totp_enabled")
  totpBackupCodes Json?    @map("totp_backup_codes") // JSONB array

  // ── Session / activity tracking ──
  lastLoginAt DateTime? @map("last_login_at")

  sessions              Session[]
  notifications         Notification[]
  viewerPerms           ViewerPermission[]
  pendingChanges        PendingChange[]
  emailOtpTokens        EmailOtpToken[]
  pendingEmailVerifs    PendingEmailVerification[]
  systemActivityLogs    SystemActivityLog[]     @relation("ActorLogs")
  targetActivityLogs    SystemActivityLog[]     @relation("TargetLogs")
  permissionAuditsMade  PermissionAuditLog[]    @relation("AuditorLogs")
  permissionAuditsOn    PermissionAuditLog[]    @relation("AuditedAccountLogs")
  emailChangeLogs       EmailChangeLog[]
  savedDbQueries        SuperAdminSavedQuery[]

  @@map("users")
}

enum UserRole {
  super_admin @map("super_admin")
  admin
  editor
  viewer
}

model Session {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  token          String   @unique
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  lastActiveAt   DateTime @default(now()) @map("last_active_at")
  isRemembered   Boolean  @default(false) @map("is_remembered")
  onboardingStep Int?     @map("onboarding_step") // F5: 1=email, 2=otp, 3=password, 4=done
  deviceHint     String?  @map("device_hint")
  ipRegion       String?  @map("ip_region")
  userAgent      String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ViewerPermission {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  allowedPages String[] @map("allowed_pages")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("viewer_permissions")
}

// ─── Home Page — Tool Categories & Tools ─────────────────────────────────────

model ToolCategory {
  id         String @id @default(cuid())
  slug       String @unique
  title      String
  parentSlug String @map("parent_slug")
  order      Int    @default(0)

  tools Tool[]

  @@index([parentSlug])
  @@map("tool_categories")
}

model Tool {
  id           String  @id @default(cuid())
  slug         String  @unique
  title        String
  url          String
  icon         String  @default("Monitor")
  description  String  @default("")
  categorySlug String  @map("category_slug")
  order        Int     @default(0)

  category ToolCategory @relation(fields: [categorySlug], references: [slug], onDelete: Cascade)

  @@index([categorySlug])
  @@map("tools")
}

// ─── Content Sections (Know More, Reports, Tracker) ──────────────────────────

model ContentSection {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  parentSlug  String  @map("parent_slug")
  description String? @default("")
  author      String?
  authorUrl   String? @map("author_url")
  content     String?
  colSpan     Int     @default(1) @map("col_span")
  order       Int     @default(0)
  buttonLabel String? @map("button_label")
  buttonUrl   String? @map("button_url")

  media  SectionMedia[]
  links  SectionLink[]
  slides SlideItem[]

  @@index([parentSlug])
  @@map("content_sections")
}

model SectionMedia {
  id        String    @id @default(cuid())
  sectionId String    @map("section_id")
  type      MediaType
  url       String?
  gurl      String?
  yurl      String?
  alt       String?
  caption   String?
  order     Int       @default(0)

  section ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("section_media")
}

enum MediaType {
  google_slides @map("google-slides")
  youtube
  image
  iframe
}

model SectionLink {
  id        String @id @default(cuid())
  sectionId String @map("section_id")
  label     String
  url       String
  order     Int    @default(0)

  section ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("section_links")
}

model SlideItem {
  id              String  @id @default(cuid())
  slug            String  @unique
  title           String  @default("")
  sectionId       String  @map("section_id")
  backgroundImage String? @map("background_image")
  layout          String  @default("single")
  order           Int     @default(0)

  section ContentSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  columns SlideColumn[]

  @@index([sectionId])
  @@map("slide_items")
}

model SlideColumn {
  id      String  @id @default(cuid())
  slideId String  @map("slide_id")
  type    String  @default("text") // "text" | "media"
  content String? // HTML text content
  order   Int     @default(0)

  // Embedded media fields (if type = "media")
  mediaType String? @map("media_type")
  mediaUrl  String? @map("media_url")
  mediaGurl String? @map("media_gurl")
  mediaYurl String? @map("media_yurl")

  slide SlideItem @relation(fields: [slideId], references: [id], onDelete: Cascade)

  @@index([slideId])
  @@map("slide_columns")
}

// ─── Modules (Top-level Navigation Entities) ─────────────────────────────────

model Module {
  id       String  @id @default(cuid())
  slug     String  @unique
  title    String
  href     String
  display  String
  order    Int     @default(0)
  format   String? @map("format") // "A" | "B" | "C" | "D" | "E" | "F"

  children String[] // Slugs of child categories/sections
  subNav   Json?    @map("sub_nav") // [{ display, href, format }]

  @@map("modules")
}

// ─── Team Page — Spine & Teams ───────────────────────────────────────────────

model SpineMember {
  id    String @id @default(cuid())
  name  String
  role  String
  img   String @default("/placeholder.jpg")
  order Int    @default(0)

  @@map("spine_members")
}

model Team {
  id    String @id @default(cuid())
  seqId Int    @unique @map("seq_id") // Original numeric ID (1, 2, etc.)
  label String

  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  id       String         @id @default(cuid())
  teamId   String         @map("team_id")
  name     String
  img      String         @default("/placeholder.jpg")
  role     TeamMemberRole
  order    Int            @default(0)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@map("team_members")
}

enum TeamMemberRole {
  head
  tl
  atl
  engineer
}

// ─── Team Drive ──────────────────────────────────────────────────────────────

model TeamDriveCategory {
  id    String @id @default(cuid())
  title String
  order Int    @default(0)

  items TeamDriveItem[]

  @@map("team_drive_categories")
}

model TeamDriveItem {
  id         String @id @default(cuid())
  categoryId String @map("category_id")
  label      String
  url        String
  urlType    String @default("url") @map("url_type") // "url" | "gurl" | "yurl"
  order      Int    @default(0)

  category TeamDriveCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("team_drive_items")
}

// ─── Inside Vortex Page ──────────────────────────────────────────────────────

model VortexCategory {
  id    String @id @default(cuid())
  title String
  order Int    @default(0)

  items VortexItem[]

  @@map("vortex_categories")
}

model VortexItem {
  id         String @id @default(cuid())
  categoryId String @map("category_id")
  content    String // The text item content
  order      Int    @default(0)

  category VortexCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("vortex_items")
}

model VortexCredit {
  id    String @id @default(cuid())
  name  String
  role  String
  order Int    @default(0)

  @@map("vortex_credits")
}

model VortexConfig {
  id            String @id @default("singleton")
  heroTitle     String @default("WHAT'S INSIDE THE VORTEX") @map("hero_title")
  heroSubtitle  String @default("") @map("hero_subtitle")
  bgType        String @default("video") @map("bg_type")
  bgValue       String @default("/laserflow.webm") @map("bg_value")

  @@map("vortex_config")
}

// ─── Report Slides (Report Page) ─────────────────────────────────────────────

model ReportSlide {
  id      String @id @default(cuid())
  label   String
  gurl    String
  colSpan Int    @default(1) @map("col_span")
  order   Int    @default(0)

  @@map("report_slides")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  page       String
  changeType String   @map("change_type") // "add" | "edit" | "delete"
  itemName   String   @map("item_name")
  username   String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

// ─── Pending Changes (Editor Approval Workflow) ──────────────────────────────

model PendingChange {
  id         String              @id @default(cuid())
  page       String
  changeType String              @map("change_type") // "add" | "edit" | "delete"
  itemName   String              @map("item_name")
  status     PendingChangeStatus @default(pending)
  /// JSON snapshot of the request payload so admin can review/revert
  snapshot   Json?
  /// The entity type and id affected (e.g. "ContentSection:slug:abc123")
  entityRef  String?             @map("entity_ref")
  /// Admin reason when declining
  reason     String?

  userId   String @map("user_id")
  username String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reviewedBy   String?  @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("pending_changes")
}

enum PendingChangeStatus {
  pending
  approved
  declined
}

// ─── Activity Log ────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  page       String
  changeType String   @map("change_type") // "add" | "edit" | "delete"
  itemName   String   @map("item_name")
  username   String
  userId     String   @map("user_id")
  status     String   @default("applied") // "applied" | "pending" | "approved" | "declined"
  /// The entity type and id affected (e.g. "ContentSection:slug:abc123")
  entityRef  String?  @map("entity_ref")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@index([entityRef])
  @@map("activity_logs")
}

// ─── Site-wide Config (Singleton) ────────────────────────────────────────────

model SiteConfig {
  id             String @id @default("singleton")
  contactEmail   String @default("gtnocradioaccess@globe.com.ph") @map("contact_email")
  headerTitle    String @default("NASA") @map("header_title")
  headerSubtitle String @default("") @map("header_subtitle")
  footerTitle    String @default("NASA") @map("footer_title")
  footerSubtitle String @default("NETWORK OPERATIONS & ASSURANCE CENTER") @map("footer_subtitle")
  footerAbout    String @default("ABOUT") @map("footer_about")
  footerSubmit   String @default("SUBMIT TOOL") @map("footer_submit")
  footerPrivacy  String @default("PRIVACY") @map("footer_privacy")
  footerTerms    String @default("TERMS") @map("footer_terms")
  footerFeedback String @default("We would love to hear your thoughts or feedback on how we can improve your experience with VORTEX.") @map("footer_feedback")
  footerSignoff  String @default("HAVE A NICE DAY!") @map("footer_signoff")
  knowMoreHeading String @default("KNOW MORE ABOUT...") @map("know_more_heading")

  // Header / Footer image (base64 data URL, replaces text when set)
  headerImage    String @default("") @map("header_image")
  footerImage    String @default("") @map("footer_image")

  // Report section
  reportHeading     String @default("RAN REPORT") @map("report_heading")
  reportSubheading  String @default("OFFICIAL NETWORK PHYSICAL LOCATION COUNT") @map("report_subheading")

  // Team Drive section
  teamDriveHeading       String  @default("TEAM DRIVE") @map("team_drive_heading")
  teamDriveNotice        String  @default("*** THIS PAGE IS FOR NOC RAN USERS ONLY ***") @map("team_drive_notice")
  teamDriveNoticeVisible Boolean @default(true) @map("team_drive_notice_visible")
  driveLabel             String  @default("DRIVE:") @map("drive_label")
  driveUrl               String  @default("") @map("drive_url")
  ranConfigHeading       String  @default("RAN CONFIGURATION PPM") @map("ran_config_heading")
  ranConfigUrl           String  @default("") @map("ran_config_url")

  // Team Drive bottom banner
  tdBottomTeams    String @default("NTG | OSCC | TAC | RAN") @map("td_bottom_teams")
  tdBottomFeedback String @default("We would love to hear your thoughts or feedback on how we can improve your experience with VORTEX. Just SCAN or CLICK the QR Code.") @map("td_bottom_feedback")
  tdBottomSignoff  String @default("Have a nice day!") @map("td_bottom_signoff")

  // Shared QR URL (used in footer + team drive)
  qrUrl String @default("https://docs.google.com/forms/d/e/1FAIpQLSf9O2wlqjlcv1uUAe-cHGNDpH6iEq7FOvNqeUl5lwP3tKdAhA/viewform") @map("qr_url")

  @@map("site_config")
}

// ─── Soft Deletes (Recycle Bin) ──────────────────────────────────────────────

model SoftDelete {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type") // e.g. "ContentSection", "Tool", "ToolCategory", etc.
  entityId    String   @map("entity_id")
  entityData  Json     @map("entity_data") // Full snapshot of deleted entity
  deletedBy   String   @map("deleted_by")
  deletedAt   DateTime @default(now()) @map("deleted_at")
  /// Auto-purge date (30 days after deletion)
  purgeAt     DateTime @map("purge_at")
  restoredAt  DateTime? @map("restored_at")

  @@index([entityType])
  @@index([purgeAt])
  @@index([restoredAt])
  @@map("soft_deletes")
}

// ─── Audit Log (Login / Logout Tracking) ─────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // "login" | "logout"
  userId    String   @map("user_id")
  username  String
  userRole  String   @map("user_role")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Email OTP Tokens (F4) ───────────────────────────────────────────────────

model EmailOtpToken {
  id           String        @id @default(cuid())
  userId       String        @map("user_id")
  otpHash      String        @map("otp_hash")
  emailUsed    String        @map("email_used") @db.VarChar(320)
  tokenType    OtpTokenType  @map("token_type")
  expiresAt    DateTime      @map("expires_at")
  consumedAt   DateTime?     @map("consumed_at")
  attemptCount Int           @default(0) @map("attempt_count")
  createdAt    DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([emailUsed])
  @@index([expiresAt])
  @@map("email_otp_tokens")
}

enum OtpTokenType {
  email_verification @map("email_verification")
  password_reset     @map("password_reset")
}

// ─── Pending Email Verifications (F5) ────────────────────────────────────────

model PendingEmailVerification {
  id                   String                     @id @default(cuid())
  userId               String                     @map("user_id")
  email                String                     @db.VarChar(320)
  status               PendingEmailStatus         @default(pending)
  createdAt            DateTime                   @default(now()) @map("created_at")
  scheduledDeletionAt  DateTime?                  @map("scheduled_deletion_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledDeletionAt])
  @@map("pending_email_verifications")
}

enum PendingEmailStatus {
  pending
  verified
  expired
  deleted
}

// ─── Permission Audit Log (F2.3) ─────────────────────────────────────────────

model PermissionAuditLog {
  id                 String   @id @default(cuid())
  whoChangedId       String   @map("who_changed_id")
  accountAffectedId  String   @map("account_affected_id")
  permissionChanged  String   @map("permission_changed")
  oldValue           String?  @map("old_value")
  newValue           String?  @map("new_value")
  changedAt          DateTime @default(now()) @map("changed_at")

  whoChanged      User @relation("AuditorLogs", fields: [whoChangedId], references: [id], onDelete: Cascade)
  accountAffected User @relation("AuditedAccountLogs", fields: [accountAffectedId], references: [id], onDelete: Cascade)

  @@index([whoChangedId])
  @@index([accountAffectedId])
  @@index([changedAt])
  @@map("permission_audit_logs")
}

// ─── System Activity Log (F12) ───────────────────────────────────────────────

model SystemActivityLog {
  id         String   @id @default(cuid())
  actorId    String   @map("actor_id")
  actionType String   @map("action_type") // login, logout, otp_sent, otp_verified, otp_failed, password_changed, email_verified, account_created, account_suspended, permission_changed, session_revoked, db_destructive_query
  targetId   String?  @map("target_id")
  metadata   Json?    // Additional context
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  immutable  Boolean  @default(false) // For db_destructive_query — cannot be deleted

  actor  User  @relation("ActorLogs", fields: [actorId], references: [id], onDelete: Cascade)
  target User? @relation("TargetLogs", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([actionType])
  @@index([targetId])
  @@index([createdAt])
  @@map("system_activity_logs")
}

// ─── Email Change Log (F10.4) ────────────────────────────────────────────────

model EmailChangeLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  oldEmail  String?  @map("old_email") @db.VarChar(320)
  newEmail  String   @map("new_email") @db.VarChar(320)
  changedBy String   @map("changed_by")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("email_change_logs")
}

// ─── Super Admin Saved Queries (F16.7) ───────────────────────────────────────

model SuperAdminSavedQuery {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  queryText String   @map("query_text")
  folder    String?
  shared    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  lastRunAt DateTime? @map("last_run_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("superadmin_saved_queries")
}
